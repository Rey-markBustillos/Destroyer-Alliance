generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int        @id @default(autoincrement())
  name      String     @default("Commander")
  playerId  String?    @unique
  email     String     @unique
  password  String
  gold      Int        @default(1200)
  buildings Building[]
}

model Building {
  id                Int       @id @default(autoincrement())
  type              String
  x                 Int
  y                 Int
  level             Int       @default(1)
  isUpgrading       Boolean   @default(false)
  upgradeCompleteAt DateTime?
  machineGold       Int       @default(0)
  lastGeneratedAt   DateTime?
  soldierCount      Int       @default(0)
  lastWagePaidAt    DateTime?
  lastFedAt         DateTime?
  hasChopper        Boolean   @default(false)
  hasTank           Boolean   @default(false)
  userId            Int
  user              User      @relation(fields: [userId], references: [id])
}
