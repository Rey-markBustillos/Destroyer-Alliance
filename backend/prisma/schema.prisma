generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        Int        @id @default(autoincrement())
  name      String     @default("Commander")
  playerId  String?    @unique
  email     String     @unique
  password  String
  gold      Int        @default(1200)
  energy    Int        @default(0)
  warPoints Int        @default(0)
  rankName  String     @default("Recruit")
  buildings Building[]
}

model Building {
  id                Int       @id @default(autoincrement())
  type              String
  x                 Int
  y                 Int
  level             Int       @default(1)
  isUpgrading       Boolean   @default(false)
  upgradeCompleteAt DateTime?
  machineGold       Int       @default(0)
  lastGeneratedAt   DateTime?
  soldierCount      Int       @default(0)
  rangerTalaCount   Int       @default(0)
  isSleeping        Boolean   @default(false)
  lastWagePaidAt    DateTime?
  lastFedAt         DateTime?
  hasChopper        Boolean   @default(false)
  hasTank           Boolean   @default(false)
  tankShotsRemaining Int      @default(0)
  chopperShotsRemaining Int   @default(0)
  userId            Int
  user              User      @relation(fields: [userId], references: [id])
}
